{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build APK (arm64 debug)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/tool/build_apk.ps1"
            ],
            "options": {
                "env": {
                    "GRADLE_USER_HOME": "${env:USERPROFILE}\\.gradle"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": []
        }
    ]
}
